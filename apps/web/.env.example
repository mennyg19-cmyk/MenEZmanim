# Copy to .env.local in this folder. Get keys from https://dashboard.clerk.com
#
# Sign-in/up paths must be /login and /register (NOT /show/login — that breaks OAuth).
# In Clerk Dashboard → Paths, set Sign-in URL to /login and Sign-up URL to /register.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin
